# Project specific data files
# We ignore raw and master datasets to prevent commits of large CSV or Excel files, 
# but we keep the directory structure by allowing .gitkeep files.
# data/raw/*
# !data/raw/.gitkeep
# data/master/*
# !data/master/.gitkeep

# Temporary or run logs
*.log
